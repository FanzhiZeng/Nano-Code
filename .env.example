# Nano Code 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# Anthropic SDK 配置
# 也适用于兼容 Anthropic API 的服务商
# ============================================

# API Key
ANTHROPIC_API_KEY=your-api-key-here

# API 基础地址
# 官方 Anthropic 可留空或填写官方地址
# 第三方兼容服务请填写对应网关地址
ANTHROPIC_BASE_URL=

# 模型 ID
# 例如 claude-sonnet-4-20250514 或第三方兼容模型名
MODEL_ID=your-model-id
